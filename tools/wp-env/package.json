{
  "name": "openclawp-wp-env",
  "version": "0.1.0",
  "description": "wp-env scaffold to run openclaWP + agents-api + wacli end-to-end in Docker. Real Linux PHP-FPM, real wacli pairing, real WhatsApp.",
  "private": true,
  "scripts": {
    "start": "wp-env start",
    "stop": "wp-env stop",
    "destroy": "wp-env destroy --scripts=false",
    "logs": "wp-env logs all",
    "wp": "wp-env run cli wp",
    "shell": "wp-env run cli bash",
    "wacli": "./bin/run-wacli.sh",
    "wacli:auth": "./bin/run-wacli.sh auth --qr-format text",
    "wacli:status": "./bin/run-wacli.sh auth status --json",
    "wacli:sync": "./bin/run-wacli-sync.sh"
  },
  "devDependencies": {
    "@wordpress/env": "^11.0.0"
  }
}
