{
  "name": "lezama/openclawp",
  "description": "Generic chat-with-an-agent WordPress plugin built on wordpress/agents-api.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "woocommerce/action-scheduler": "^3.9",
    "wordpress/agents-api": "dev-main"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "suggest": {
    "wordpress/php-ai-client": "Required only on WordPress < 7.0. WP 7.0+ ships the AI Client in core (wp-includes/php-ai-client); including a second copy here causes namespace conflicts with bundled-and-prefixed deps."
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/Automattic/agents-api"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.1.0"
    },
    "sort-packages": true
  },
  "scripts": {
    "test": "php -d auto_prepend_file=tests/phpunit-prepend.php vendor/phpunit/phpunit/phpunit",
    "test:smoke": "php tests/smoke.php",
    "test:assembly": "php -d auto_prepend_file=tests/phpunit-prepend.php vendor/phpunit/phpunit/phpunit --testsuite assembly",
    "lint:php": "phpcs",
    "lint:php:fix": "phpcbf",
    "analyse": "phpstan analyse"
  }
}
